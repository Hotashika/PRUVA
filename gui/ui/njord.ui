     <property name="styleSheet">
      <string notr="true">/* Ana Kutu Görünümü */
QComboBox {
    background-color: #2c3e50;
    color: #ecf0f1;
    border: 2px solid #34495e;
    border-radius: 12px;
    padding: 8px 30px 8px 12px;
    font-weight: bold;
}

/* Sağdaki ok alanı (Drop-down konteyneri) */
QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 25px; 
    border-left: 1px solid #34495e;
}

/* OK SİMGESİ (Çizim Kısmı) */
QComboBox::down-arrow {
    image: none; /* Dış resmi iptal ettik */
    width: 0;
    height: 0;
    border-left: 6px solid transparent; /* Sol kenar görünmez */
    border-right: 6px solid transparent; /* Sağ kenar görünmez */
    border-top: 8px solid #ecf0f1; /* Sadece üst kenar renkli: Bu gerçek bir ok oluşturur */
    margin-top: 2px;
}

/* Okun üzerine gelince veya kutu açılınca renk değişimi */
QComboBox::down-arrow:on { 
    border-top: 8px solid #3498db; /* Açıldığında mavi olur */
}

/* Liste açıldığında seçeneklerin stili */
QComboBox QAbstractItemView {
    background-color: #1a1a1a;
    color: #bdc3c7;
    selection-background-color: #3498db;
    selection-color: white;
    outline: none;
}</string>
