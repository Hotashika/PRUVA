      <property name="styleSheet">
       <string notr="true">QPushButton {
    color: black;              /* Yazı rengi siyah */
    background-color: white;   /* Arka plan beyaz (yazı siyah olacağı için en iyisi bu) */
    border: 2px solid #00D2FF; /* Çerçeve turkuaz mavi */
    border-radius: 4px;        /* Köşeleri yumuşatır */
    padding: 5px;              /* Yazı çerçeveye çok yapışmasın */
    font-weight: bold;         /* Yazıyı daha belirgin yapar */
}

/* Fare üzerine geldiğinde renkler biraz canlansın */
QPushButton:hover {
    background-color: #f0fbff; /* Çok açık mavi arka plan */
    border: 2px solid #00A3CC; /* Daha koyu bir turkuaz çerçeve */
}

/* Butona basıldığında tepki versin */
QPushButton:pressed {
    background-color: #00D2FF; /* Arka plan tamamen turkuaz olur */
    color: white;              /* Basılınca yazı beyaza döner (havalı durur) */
}</string>
